<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

{% set pageTitle = title + " — " + site.title if title else site.title %}
{% set pageDescription = description if description else site.description %}
{% set ogImage = media[0].src | absoluteMediaUrl if media and media.length > 0 else "" %}
{% set pageUrl = (site.url | default("")) + page.url %}

<title>{{ pageTitle }}</title>
<meta name="description" content="{{ pageDescription }}">

<meta property="og:site_name" content="{{ site.title }}">
<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:description" content="{{ pageDescription }}">
<meta property="og:type" content="{{ 'article' if title else 'website' }}">
{% if site.url %}<meta property="og:url" content="{{ pageUrl }}">{% endif %}
{% if ogImage %}<meta property="og:image" content="{{ ogImage }}">{% endif %}

<meta name="twitter:card" content="{{ 'summary_large_image' if ogImage else 'summary' }}">
<meta name="twitter:title" content="{{ pageTitle }}">
<meta name="twitter:description" content="{{ pageDescription }}">
{% if ogImage %}<meta name="twitter:image" content="{{ ogImage }}">{% endif %}

<link rel="stylesheet" href="/styles/fonts.css">
<link rel="stylesheet" href="/styles/main.css">
<link rel="stylesheet" href="/styles/custom.css">
<style>:root { --accent: {{ site.accent_color | default("#1a1a1a") }}; }</style>

<!-- Prefetch same-origin pages on hover so cross-document view transitions
     land render-ready in Chrome (Safari/Arc already preload). -->
<script type="speculationrules">
{
  "prefetch": [
    { "source": "document", "where": { "href_matches": "/*" }, "eagerness": "moderate" }
  ]
}
</script>
